# Copy this file to `.env` and fill in values. `.env` is gitignored.
# EVERYTHING here is optional. With no keys set, the tool runs fully locally:
#   - flight data comes from the built-in mock provider
#   - alerts print to the console instead of emailing (dry run)

# --- Flight data (Duffel) ---
# Leave blank to use the mock provider. Set to a Duffel test/sandbox token to use real data.
DUFFEL_API_KEY=

# Force a provider regardless of keys: auto | duffel | mock  (default: auto)
PROVIDER=auto

# --- Email alerts (Resend) ---
# Leave blank to print alerts to the console. Set both to actually send email.
RESEND_API_KEY=
ALERT_FROM=onboarding@resend.dev
ALERT_TO=

# --- Alert tuning (all optional; sensible defaults in src/config.ts) ---
# DROP_PCT=0.1            # how far below "typical" counts as a drop (0.1 = 10%)
# LOW_WINDOW_DAYS=30      # window for "new N-day low"
# COOLDOWN_HOURS=24       # min hours between alerts for the same watch
# PERSIST_CHECKS=2        # consecutive checks under threshold before a drop alert
# FLEX_DAYS=2             # +/- days searched around each date
# MAX_API_CALLS_PER_RUN=10
# OFFERS_PER_SEARCH=3
